# ── Sync Server ────────────────────────────────────────────────────────────────
# Secret key for server-side encryption (defense in depth).
# Generate with: openssl rand -hex 32
# If not set, a default key is used (NOT SECURE for production).
SYNC_SERVER_KEY=your-random-secret-key-here

# Port for the sync server (default: 3001, nginx proxies to this)
SYNC_PORT=3001

# Directory for SQLite database (default: /data/sync)
# Mount as a Docker volume for persistence across deploys.
SYNC_DATA_DIR=/data/sync
